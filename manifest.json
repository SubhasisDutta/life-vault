{
  "manifest_version": 3,
  "name": "Family Life Vault",
  "version": "1.3.0",
  "description": "Comprehensive Digital Legacy & Estate Organization System - Organize everything your family needs in one place",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open Family Life Vault"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage"
  ]
}